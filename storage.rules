rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to everyone
      allow read: if true;
      // Allow write access only to the admin email
      allow write: if request.auth != null && request.auth.token.email == "sloudsan@gmail.com";
    }
  }
}
